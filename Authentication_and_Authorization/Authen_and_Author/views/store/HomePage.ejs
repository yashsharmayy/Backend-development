<%- include('../partials/head') %>

  <body class="bg-gray-100 min-h-screen flex flex-col items-center justify-center">
<%- include('../partials/navbar') %>
    <div class="flex gap-8 items-start">

      <div class="bg-white w-125 p-10 rounded-xl shadow-lg text-center">
        <h1 class="text-4xl font-bold text-blue-600 mb-5">
          🏠 Welcome to My Website
        </h1>

        <p class="text-gray-600 text-lg mb-8">
          Register your home quickly using our simple form.
        </p>

        <a
          href="/host/add-home"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition duration-300"
        >
          Add Home
        </a>
      </div>

      <div class="bg-white w-72 p-6 rounded-xl shadow-lg">
        <ul class="space-y-3">
          <% registrationForm.forEach(uname => { %>
            <li class="bg-gray-100 border border-gray-200 rounded-lg px-4 py-3 text-gray-800 font-medium shadow-sm">
              <%= uname.userName %>
            </li>
          <% }) %>
        </ul>
      </div>

    </div>

  </body>
</html>