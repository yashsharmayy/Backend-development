<nav class="navbar">
  <div class="container">

    <a href="/" class="logo">🏠 Airbnb Clone</a>

<ul class="nav-links">
  <li><a href="/">Home</a></li>

  <% if (isLoggedIn && user) { %>

    <% if (user.userType === "guest") { %>

      <li class="dropdown">
        <button class="drop-btn">Store ▾</button>

        <div class="dropdown-content">
          <a href="/homeList/homeCard">All Homes</a>
          <a href="/booking">My Bookings</a>
          <a href="/homeList/favourites">Favourite Homes</a>
          <a href="/reserve">Reserve Home</a>
        </div>
      </li>

    <% } %>

    <% if (user.userType === "host") { %>

      <li class="dropdown">
        <button class="drop-btn">Admin ▾</button>

        <div class="dropdown-content">
          <a href="/host/add-home">Add Home</a>
          <a href="/host/admin-home-list">Home List</a>
        </div>
      </li>

    <% } %>

  <% } %>
</ul>

    <div class="right-menu">

      <% if (isLoggedIn) { %>




      <a href="/homeList/favourites">❤️</a>
      <a href="/booking">📅</a>

      <form action="/logout" method="POST">
        <button type="submit" class="logout-btn">
          Logout
        </button>
      </form>

      <% } else { %>

      <a href="/login" class="login-btn">
        Login
      </a>
      <a href="/signup" class="login-btn">
        sign up
      </a>

      <% } %>

    </div>

  </div>
</nav>

<div style="height:70px;"></div>

<style>
*{
   
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

.navbar{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    background:#fff;
    box-shadow:0 2px 10px rgba(0,0,0,.1);
    z-index:1000;
}

.container{
    max-width:1200px;
    height:70px;
    margin:auto;
    padding:0 20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    text-decoration:none;
    font-size:28px;
    font-weight:bold;
    color:#2563eb;
}

.nav-links{
    list-style:none;
    display:flex;
    gap:30px;
    align-items:center;
}

.nav-links li{
    position:relative;
}

.nav-links a,
.drop-btn{
    text-decoration:none;
    padding: 20px;
    color:#333;
    font-size:16px;
    background:none;
    border:none;
    cursor:pointer;
}

.nav-links a:hover,
.drop-btn:hover{
