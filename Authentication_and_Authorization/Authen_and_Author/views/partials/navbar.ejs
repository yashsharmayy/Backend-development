    padding:12px 16px;
}

.dropdown-content a:hover{
    background:#f3f4f6;
}

.dropdown:hover .dropdown-content{
    display:block;
}

.right-menu{
    display:flex;
    align-items:center;
    gap:15px;
}

.right-menu a{
    text-decoration:none;
    font-size:15px;
}

.login-btn,
.logout-btn{
    padding:10px 18px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    text-decoration:none;
    color:#fff;
    font-size:10px;
    transition:.3s;
}

.login-btn{
    background:#2563eb;
}

.login-btn:hover{
    background:#1d4ed8;
}

.logout-btn{
    background:#ef4444;
}

.logout-btn:hover{
    background:#dc2626;
}
</style>