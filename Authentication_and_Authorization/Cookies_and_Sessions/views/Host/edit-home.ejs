<%- include('../partials/head') %>

<body class="bg-gray-100 min-h-screen">
  <%- include('../partials/navbar') %>

  <div class="max-w-3xl mx-auto mt-10 bg-white rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-800">✏️ Edit Home</h1>
      <p class="text-gray-500 mt-2">Update the details of your property.</p>
    </div>

    <form
      action="/host/edit-home/<%= home._id %>"
      method="POST"
      class="space-y-6"
    >
      <div>
        <label class="block text-gray-700 font-semibold mb-2">
          Owner Name
        </label>
        <input
          type="text"
          name="ownerName"
          value="<%= home.ownerName %>"
          required
          class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
        />
      </div>

      <div>
        <label class="block text-gray-700 font-semibold mb-2">
          Home Name
        </label>
        <input
          type="text"
          name="homeName"
          value="<%= home.homeName %>"
          required
          class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
        />
      </div>

      <div class="grid grid-cols-2 gap-6">
        <div>
          <label class="block text-gray-700 font-semibold mb-2"> Price </label>
          <input
            type="number"
            name="price"
            value="<%= home.price %>"
            required
            class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
          />
        </div>

        <div>
          <label class="block text-gray-700 font-semibold mb-2"> Rating </label>
          <input
            type="number"
            step="0.1"
            min="0"
            max="5"
            name="rating"
            value="<%= home.rating %>"
            required
            class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
          />
        </div>
      </div>

      <div>
        <label class="block text-gray-700 font-semibold mb-2"> Location </label>
        <input
          type="text"
          name="location"
          value="<%= home.location %>"
          required
          class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
        />
      </div>

      <div>
        <label class="block text-gray-700 font-semibold mb-2">
          Image URL
        </label>
        <input
          type="text"
          name="photo"
          value="<%= home.photo %>"
          required
          class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
        />
      </div>

      <div class="text-center">
        <img
          src="<%= home.photo %>"
          alt="Home Image"
          class="w-full h-64 object-cover rounded-lg border"
        />
      </div>
      <div>
        <label class="block text-gray-700 font-semibold mb-2">
          Description
        </label>
        <textarea
          name="description"
          rows="4"
          required
          class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none resize-none"
        >
          <%= home.description %></textarea
        >
      </div>

      <div class="flex justify-between">
        <a
          href="/host/admin-home-list"
          class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600"
        >
          Cancel
        </a>

        <button
          type="submit"
          class="bg-blue-600 text-white px-8 py-2 rounded-lg hover:bg-blue-700 transition"
        >
          💾 Update Home
        </button>
      </div>
    </form>
  </div>
</body>
