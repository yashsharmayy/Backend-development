<%- include('../partials/head') %>

<body class="bg-gray-100 min-h-screen">
  <%- include('../partials/navbar') %>

  <div class="max-w-3xl mx-auto mt-10 bg-white rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold">✏️ Edit Home</h1>
      <p class="text-gray-500">Update your property details.</p>
    </div>

    <form
      action="/host/edit-home/<%= home._id %>"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-6"
    >
      <div>
        <label class="font-semibold">Owner Name</label>
        <input
          type="text"
          name="ownerName"
          value="<%= home.ownerName %>"
          class="w-full border rounded-lg px-4 py-2"
          required
        />
      </div>

      <div>
        <label class="font-semibold">Home Name</label>
        <input
          type="text"
          name="homeName"
          value="<%= home.homeName %>"
          class="w-full border rounded-lg px-4 py-2"
          required
        />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="font-semibold">Price</label>
          <input
            type="number"
            name="price"
            value="<%= home.price %>"
            class="w-full border rounded-lg px-4 py-2"
            required
          />
        </div>

        <div>
          <label class="font-semibold">Rating</label>
          <input
            type="number"
            step="0.1"
            name="rating"
            value="<%= home.rating %>"
            class="w-full border rounded-lg px-4 py-2"
            required
          />
        </div>
      </div>

      <div>
        <label class="font-semibold">Location</label>
        <input
          type="text"
          name="location"
          value="<%= home.location %>"
          class="w-full border rounded-lg px-4 py-2"
          required
        />
      </div>

      <div>
        <label class="font-semibold">Current Image</label>

       <img
          src="<%= home.photo ? '/uploads/' + home.photo : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800' %>"
          alt="<%= home.homeName %>"
        >

      <div>
        <label class="font-semibold"> Change Image (Optional) </label>

        <input
          type="file"
          name="photo"
          accept="image/*"
          class="w-full border rounded-lg px-4 py-2"
        />
      </div>

      <div>
        <label class="font-semibold">Description</label>

        <textarea
          name="description"
          rows="4"
          class="w-full border rounded-lg px-4 py-2"
          required
        >
<%= home.description %></textarea
        >
      </div>

      <div class="flex justify-between">
        <a
          href="/host/admin-home-list"
          class="bg-gray-500 text-white px-6 py-2 rounded-lg"
        >
          Cancel
        </a>

        <button
          type="submit"
          class="bg-blue-600 text-white px-8 py-2 rounded-lg"
        >
          Update Home
        </button>
      </div>
    </form>
  </div>
</body>
