<%- include('../partials/head') %>

<body class="bg-slate-100 min-h-screen">

<%- include('../partials/navbar') %>

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Heading -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-5">

        <div>
            <h1 class="text-4xl font-extrabold text-gray-800">
                🏡 Explore Homes
            </h1>

            <p class="text-gray-500 mt-2 text-lg">
                Find your perfect stay from our beautiful collection.
            </p>
        </div>

        <a
            href="/homeList/homeForm"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transition duration-300"
        >
            + Add Home
        </a>

    </div>

    <% if(homes.length === 0){ %>

    <div class="bg-white rounded-3xl shadow-lg p-16 text-center">

        <h2 class="text-3xl font-bold text-gray-700">
            No Homes Available
        </h2>

        <p class="text-gray-500 mt-3 mb-8">
            Register your first home and start hosting.
        </p>

        <a
            href="/homeList/homeForm"
            class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl"
        >
            Register Home
        </a>

    </div>

    <% } else { %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

        <% homes.forEach(home => { %>

        <div class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-2 duration-300">

            <!-- Image -->
            <div class="relative">

              <img
                src="<%= home.photo ? '/uploads/' + home.photo : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800' %>"
                alt="<%= home.homeName %>"
                >
                <!-- Rating -->
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full font-semibold shadow">
                    ⭐ <%= home.rating %>
                </div>

                <!-- Favorite -->
                 <div class="m-4 ">

                     <%- include('../partials/favorites',{home:home}) %>
                 </div>


            </div>

            <!-- Card Content -->
            <div class="p-6">

                <div class="flex justify-between items-start">

                    <div>
                        <h2 class="text-xl font-bold text-gray-800">
                            <%= home.homeName %>
                        </h2>

                        <p class="text-gray-500 text-sm mt-1">
                            👤 <%= home.ownerName %>
                        </p>
                    </div>

                    <div class="text-right">

                        <p class="text-green-600 font-bold text-2xl">
                            ₹<%= home.price %>
                        </p>

                        <span class="text-xs text-gray-500">
                            / night
                        </span>

                    </div>

                </div>

                <div class="mt-4 text-gray-600 text-sm flex items-center gap-2">
                    📍
                    <span><%= home.location %></span>
                </div>

                <!-- Buttons -->
                <div class="mt-6 grid grid-cols-2 gap-3">

                    <a
                        href="/homeList/home/<%= home._id %>"
                        class="text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 rounded-xl transition"
                    >
                        View Details
                    </a>

                    <a
                        href="/booking/<%= home._id %>"
                        class="text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition"
                    >
                        Book Now
                    </a>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <% } %>

</div>

</body>
</html>