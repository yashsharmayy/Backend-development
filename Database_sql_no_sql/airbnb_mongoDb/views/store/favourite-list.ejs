<%- include('../partials/head') %>

<body class="bg-slate-100 min-h-screen">

<%- include('../partials/navbar') %>

<div class="max-w-7xl mx-auto px-6 py-10">

    <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-5">

        <div>
            <h1 class="text-4xl font-extrabold text-gray-800">
                ❤️ My Favourite Homes
            </h1>

            <p class="text-gray-500 mt-2 text-lg">
                Your saved homes in one place.
            </p>
        </div>

        <a
            href="/homeList/homeCard"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl shadow-lg transition"
        >
            ← Explore More Homes
        </a>

    </div>

    <% if (!homes || homes.length === 0) { %>

        <div class="bg-white rounded-3xl shadow-lg p-16 text-center">

            <div class="text-7xl mb-5">💔</div>

            <h2 class="text-3xl font-bold text-gray-700">
                No Favourite Homes
            </h2>

            <p class="text-gray-500 mt-3 mb-8">
                Save your favourite homes and they'll appear here.
            </p>

            <a
                href="/homeList/homeCard"
                class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl"
            >
                Browse Homes
            </a>

        </div>

    <% } else { %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

        <% homes.forEach(home => { %>

        <div class="bg-white rounded-3xl overflow-hidden shadow-lg">

            <img
                src="<%= home.photo %>"
                alt="<%= home.homeName %>"
                class="w-full h-60 object-cover"
            >

            <div class="p-6">

                <h2 class="text-xl font-bold">
                    <%= home.homeName %>
                </h2>

                <p class="text-gray-500">
                    👤 <%= home.ownerName %>
                </p>

                <p class="text-gray-600 mt-2">
                    📍 <%= home.location %>
                </p>

                <p class="text-green-600 text-xl font-bold mt-2">
                    ₹<%= home.price %>
                </p>

                <p class="mt-2">
                    ⭐ <%= home.rating %>
                </p>

                <div class="flex gap-3 mt-5">

                    <a
                        href="/homeList/home/<%= home._id %>"
                        class="bg-black text-white px-4 py-2 rounded-lg"
                    >
                        Details
                    </a>

                    <a
                        href="/homeList/booking"
                        class="bg-blue-600 text-white px-4 py-2 rounded-lg"
                    >
                        Book
                    </a>

                </div>

                <form action="/homeList/favourites/delete" method="POST" class="mt-4">

                    <input
                        type="hidden"
                        name="homeId"
                        value="<%= home._id %>"
                    >

                    <button
                        class="w-full bg-red-500 text-white py-2 rounded-lg"
                    >
                        Remove Favourite
                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

    <% } %>

</div>

</body>
</html>