<%- include('../partials/head') %>

<body class="bg-gray-100 min-h-screen">

<%- include('../partials/navbar') %>

<div class="max-w-6xl mx-auto px-5 py-8">

    <% if(home){ %>

    <!-- Main Card -->
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">

        <!-- Image -->
        <div class="relative h-112 overflow-hidden">
            <img
                src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1200"
                alt="<%= home.homeName %>"
                class="w-full h-full object-cover"
            >

            <div class="absolute top-5 right-5">
                <span class="bg-yellow-400 text-black px-4 py-2 rounded-full font-bold shadow">
                    ⭐ <%= home.rating %>
                </span>
            </div>
        </div>

        <!-- Details -->
        <div class="p-8">

            <div class="flex justify-between items-center mb-6">
                <h1 class="text-4xl font-bold text-gray-800">
                    <%= home.homeName %>
                </h1>

                <span class="text-3xl font-bold text-green-600">
                    ₹<%= home.price %>/night
                </span>
            </div>

            <div class="grid md:grid-cols-2 gap-6">

                <!-- Left -->
                <div class="space-y-5">

                    <div class="bg-gray-50 p-5 rounded-xl">
                        <h2 class="text-xl font-semibold mb-3">
                            Property Details
                        </h2>

                        <p class="mb-2">
                            <strong>👤 Owner:</strong>
                            <%= home.ownerName %>
                        </p>

                        <p class="mb-2">
                            <strong>📍 Location:</strong>
                            <%= home.location %>
                        </p>

                        <p class="mb-2">
                            <strong>⭐ Rating:</strong>
                            <%= home.rating %> / 5
                        </p>

                        <p>
                            <strong>💰 Price:</strong>
                            ₹<%= home.price %> per night
                        </p>
                    </div>

                </div>

                <!-- Right -->
                <div class="bg-gray-50 p-5 rounded-xl">

                    <h2 class="text-xl font-semibold mb-4">
                        Description
                    </h2>

                    <p class="text-gray-600 leading-7">
                        Enjoy a comfortable and relaxing stay at
                        <strong><%= home.homeName %></strong>.
                        Located in <strong><%= home.location %></strong>,
                        this property offers a peaceful environment,
                        modern amenities, and an excellent experience for
                        families, couples, and business travelers.
                    </p>

                    <div class="mt-8 flex gap-3">

                        <a
                            href="/host/admin-home-list"
                            class="px-6 py-3 bg-gray-800 hover:bg-black text-white rounded-lg"
                        >
                            ← Back
                        </a>

                        <a
                            href="/host/edit-home/<%= home._id %>"
                            class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg"
                        >
                            ✏ Edit
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <% } else { %>

    <div class="bg-white rounded-2xl shadow p-10 text-center">

        <h1 class="text-3xl font-bold text-red-600">
            Home Not Found
        </h1>

        <p class="text-gray-500 mt-3">
            The property you are looking for doesn't exist.
        </p>

        <a
            href="/"
            class="inline-block mt-6 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700"
        >
            Back to Home
        </a>

    </div>

    <% } %>

</div>

</body>
</html>