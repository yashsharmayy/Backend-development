<%- include('partials/head') %>

<body class="bg-gray-100 min-h-screen">

<%- include('partials/navbar') %>

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Heading -->
    <div class="flex items-center justify-between mb-10">

        <div>
            <h1 class="text-4xl font-bold text-gray-800">
                🏡 Explore Homes
            </h1>

            <p class="text-gray-500 mt-2">
                Discover amazing places to stay.
            </p>
        </div>

        <a
            href="/homeList/homeForm"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl shadow-lg transition"
        >
            + Add Home
        </a>

    </div>

    <% if(homes.length === 0){ %>

        <div class="bg-white rounded-2xl shadow-lg p-12 text-center">

            <h2 class="text-3xl font-bold text-gray-700 mb-3">
                No Homes Found
            </h2>

            <p class="text-gray-500 mb-8">
                Register your first home to get started.
            </p>

            <a
                href="/homeList/homeForm"
                class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl"
            >
                Register Home
            </a>

        </div>

    <% } else { %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

        <% homes.forEach(home => { %>

        <div class="bg-white rounded-3xl shadow-lg overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition duration-300">

            <!-- Image -->
            <div class="relative">

                <img
                    src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=700"
                    alt="Home"
                    class="w-full h-60 object-cover"
                >

                <div class="absolute top-4 right-4 bg-white px-3 py-1 rounded-full shadow font-semibold">
                    ⭐ <%= home.rating %>
                </div>

            </div>

            <!-- Content -->
            <div class="p-6">

                <h2 class="text-2xl font-bold text-gray-800 mb-2">
                    <%= home.homeName %>
                </h2>

                <p class="text-gray-500 mb-4">
                    👤 <%= home.ownerName %>
                </p>

                <p class="text-gray-600 mb-2">
                    📍 <%= home.location %>
                </p>

                <div class="flex items-center justify-between mt-6">

                    <div>
                        <span class="text-2xl font-bold text-green-600">
                            ₹<%= home.price %>
                        </span>

                        <p class="text-sm text-gray-500">
                            per night
                        </p>
                    </div>

                    <button
                        class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl transition"
                    >
                        View Details
                    </button>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <% } %>

</div>

</body>
</html>