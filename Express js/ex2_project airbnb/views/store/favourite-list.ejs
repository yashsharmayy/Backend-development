<%- include('../partials/head') %>

<body class="bg-slate-100 min-h-screen">

<%- include('../partials/navbar') %>

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-5">

        <div>
            <h1 class="text-4xl font-extrabold text-gray-800">
                ❤️ My Favourite Homes
            </h1>

            <p class="text-gray-500 mt-2 text-lg">
                Your saved homes in one place.
            </p>
        </div>

        <a
            href="/homeList/homeCard"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl shadow-lg transition"
        >
            ← Explore More Homes
        </a>

    </div>

    <% if(homes.length === 0){ %>

        <div class="bg-white rounded-3xl shadow-lg p-16 text-center">

            <div class="text-7xl mb-5">
                💔
            </div>

            <h2 class="text-3xl font-bold text-gray-700">
                No Favourite Homes
            </h2>

            <p class="text-gray-500 mt-3 mb-8">
                Save your favourite homes and they'll appear here.
            </p>

            <a
                href="/homeList/homeCard"
                class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl"
            >
                Browse Homes
            </a>

        </div>

    <% } else { %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

        <% homes.forEach(home => { %>

        <div class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-2 transition duration-300">

            <!-- Image -->
            <div class="relative">

                <img
                    src="<%= 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=700' %>"
                    alt="<%= home.homeName %>"
                    class="w-full h-60 object-cover"
                >

                <div class="absolute top-4 right-4 bg-white px-3 py-1 rounded-full shadow font-semibold">
                    ⭐ <%= home.rating %>
                </div>

                <div class="absolute top-4 left-4 bg-red-500 text-white px-3 py-1 rounded-full shadow">
                    ❤️ Favourite
                </div>

            </div>

            <!-- Content -->
            <div class="p-6">

                <div class="flex justify-between items-start">

                    <div>
                        <h2 class="text-xl font-bold text-gray-800">
                            <%= home.homeName %>
                        </h2>

                        <p class="text-gray-500 text-sm mt-1">
                            👤 <%= home.ownerName %>
                        </p>
                    </div>

                    <div class="text-right">

                        <p class="text-2xl font-bold text-green-600">
                            ₹<%= home.price %>
                        </p>

                        <span class="text-xs text-gray-500">
                            / night
                        </span>

                    </div>

                </div>

                <div class="mt-4 text-gray-600">
                    📍 <%= home.location %>
                </div>

                <!-- Buttons -->
                <div class="grid grid-cols-2 gap-3 mt-6">

                    <a
                        href="/homeList/home/<%= home.id %>"
                        class="text-center bg-gray-900 hover:bg-black text-white py-3 rounded-xl font-semibold transition"
                    >
                        View Details
                    </a>

                    <a
                        href="/homeList/booking"
                        class="text-center bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-semibold transition"
                    >
                        Book Now
                    </a>

                </div>

                <!-- Remove Favourite -->
                <form
                    action="/homeList/remove-favourite"
                    method="POST"
                    class="mt-4"
                >

                    <input
                        type="hidden"
                        name="id"
                        value="<%= home.id %>"
                    >

                    <button
                        class="w-full bg-red-100 hover:bg-red-500 hover:text-white text-red-600 py-3 rounded-xl font-semibold transition"
                    >
                        🗑 Remove from Favourite
                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

    <% } %>

</div>

</body>
</html>